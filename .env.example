# Database
DATABASE_URL=postgresql://lifetext:password@localhost:5432/lifetext

# Redis
REDIS_URL=redis://localhost:6379

# LLM Provider Configuration
# Supported: openai, anthropic, gemini, deepseek, openai-compatible
LLM_PROVIDER=anthropic
LLM_API_KEY=your-api-key-here
LLM_MODEL=claude-sonnet-4-20250514
# LLM_BASE_URL=http://localhost:11434/v1  # For openai-compatible (Ollama, etc)

# Examples for different providers:
# OpenAI: LLM_PROVIDER=openai, LLM_MODEL=gpt-4
# Gemini: LLM_PROVIDER=gemini, LLM_MODEL=gemini-2.0-flash-exp
# DeepSeek: LLM_PROVIDER=deepseek, LLM_MODEL=deepseek-chat
# Ollama: LLM_PROVIDER=openai-compatible, LLM_MODEL=llama3, LLM_BASE_URL=http://localhost:11434/v1

# Whisper
WHISPER_MODEL_SIZE=base

# App settings
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production

# User (for development, no auth yet)
DEVELOPMENT_USER_ID=dev-user-123
